# =============================================================================
# ROOT – shared env (never commit .env)
# Copy to .env at project root. Backend and frontend load this when run locally.
#
# Hostinger CI/CD uses docker-compose.deploy.yml (app + monitoring). Local equivalent:
#   yarn compose -f docker-compose.deploy.yml up -d
#
# Docker Compose: use `yarn compose …` or `yarn docker:*` / `yarn docker:prod:*` — they run
# scripts/compose-with-env.sh, which merges (if present) .env + backend/.env + frontend/.env
# for compose variable interpolation. Later files override duplicate keys.
# Plain `docker compose --env-file .env` only loads the root file.
#
# Auth: JWT_SECRET, JWT_ACCESS_EXPIRES_IN, JWT_REFRESH_EXPIRES_IN, CORS — see
#   backend/env.example → backend/.env
#
# API URL + E2E (Playwright) credentials: NEXT_PUBLIC_API_URL, E2E_TEST_PASSWORD, E2E_TEST_EMAIL
#   — see frontend/env.example → frontend/.env and documentation/ENVIRONMENT_SETUP.md
# Full checklist: documentation/private/CODEBASE_AUDIT_GRID.md
# =============================================================================

NODE_ENV=development
FRONTEND_PORT=3002
BACKEND_PORT=4002

# Database host port exposed on your machine
POSTGRES_PORT=5433

# --- Required for docker-compose.prod.yml (can live in backend/.env; merged by compose-with-env.sh) ---
# POSTGRES_PASSWORD=change_me_strong_db_password
# JWT_SECRET=change_me_min_32_chars_random

# Docker-internal service routing (backend <-> postgres, frontend <-> backend)
POSTGRES_HOST_DOCKER=postgres
POSTGRES_PORT_DOCKER=5432
BACKEND_URL_DOCKER=http://memoon-card-backend:4002

# --- Optional: docker-compose.monitoring.yml (Loki / Grafana / Promtail) ---
# GRAFANA_ADMIN_USER=admin
# GRAFANA_ADMIN_PASSWORD=change_me_strong_password
# GRAFANA_ROOT_URL=http://127.0.0.1:3333
# GRAFANA_PORT=3333
# LOKI_PORT=3100
# PROMETHEUS_PORT=9090
# CADVISOR_PORT=8088
