# Audit: JWT_SECRET and DB passwords are secrets — never commit .env (grid 1.1, 7.2).
# See documentation/ENVIRONMENT_SETUP.md and documentation/private/CODEBASE_AUDIT_GRID.md.

# -----------------------------------------------------------------------------
# JWT
# -----------------------------------------------------------------------------
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-long-change-this-in-production
# Access token: 15m = strict; 1h recommended for prod/mobile to reduce re-login (frontend refreshes proactively).
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
# Optional: longer refresh when user checks "trust this device" (default 30d)
# JWT_REFRESH_TRUSTED_EXPIRES_IN=30d

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
CORS_ORIGIN=http://localhost:3002
# CORS_ORIGINS=http://localhost:3002,https://yourdomain.com

# -----------------------------------------------------------------------------
# RATE LIMITING
# -----------------------------------------------------------------------------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
# Login + register only (refresh/session excluded). Production default 30 per 15 min per IP; dev uses 2000.
# AUTH_RATE_LIMIT_WINDOW_MS=900000
# AUTH_RATE_LIMIT_MAX=50
# Forgot / reset password (per IP). Defaults: 5/hour and 10/hour.
# FORGOT_PASSWORD_RATE_LIMIT_WINDOW_MS=3600000
# FORGOT_PASSWORD_RATE_LIMIT_MAX=5
# RESET_PASSWORD_RATE_LIMIT_WINDOW_MS=3600000
# RESET_PASSWORD_RATE_LIMIT_MAX=10
# Per-email hash bucket for forgot-password (distributed abuse). Defaults 3/hour.
# FORGOT_PASSWORD_EMAIL_RATE_LIMIT_WINDOW_MS=3600000
# FORGOT_PASSWORD_EMAIL_RATE_LIMIT_MAX=3
MAX_REQUEST_SIZE=10mb

# -----------------------------------------------------------------------------
# DATABASE (for local dev: MemoOn Postgres in Docker uses host port 5433)
# -----------------------------------------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=memoon_card_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# -----------------------------------------------------------------------------
# Dev user (optional): create/update a user with role "dev" on backend startup
# Set all three to enable. Useful for staging or dev VPS access.
# -----------------------------------------------------------------------------
# DEV_EMAIL=dev@example.com
# DEV_PASSWORD=your-dev-password
# DEV_USERNAME=Dev User
