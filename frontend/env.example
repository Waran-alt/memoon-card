# Audit: nothing secret in NEXT_PUBLIC_* (embedded in client bundle, grid 4.1).
# E2E password only in local .env (gitignored).

# -----------------------------------------------------------------------------
# FRONTEND
# -----------------------------------------------------------------------------
# When behind nginx (e.g. https://memoon-card.localhost), set to empty so API
# calls use same origin and the refresh cookie works. Otherwise set backend URL.
NEXT_PUBLIC_API_URL=https://memoon-card.localhost
# BACKEND_URL set by Docker Compose for frontend container; leave unset for local dev

# Browser error reports to POST /api/client-errors (prod on by default). Set false to disable.
# NEXT_PUBLIC_CLIENT_ERROR_REPORTING=false
# Enable in local dev:
# NEXT_PUBLIC_CLIENT_ERROR_REPORTING=true

# -----------------------------------------------------------------------------
# E2E (Playwright) – optional; only needed when running yarn test:e2e
# -----------------------------------------------------------------------------
# playwright.config.ts loads this file; E2E_BASE_URL or PLAYWRIGHT_BASE_URL sets baseURL.
# Use a full URL (e.g. https://memoon-card.localhost). Bare hostnames are normalized (https).
# If base URL is https://memoon-card.localhost, set NEXT_PUBLIC_API_URL="" for same-origin cookies.
# E2E_BASE_URL=https://memoon-card.localhost
# PLAYWRIGHT_BASE_URL=
# E2E_TEST_PASSWORD=      # password for the test user (register/login in tests)
# E2E_TEST_EMAIL=         # optional; default e2e@test.local
# E2E_BACKEND_URL=        # optional; default http://127.0.0.1:4002 — used by e2e/stack-health.spec.ts for GET /health

# -----------------------------------------------------------------------------
# Dev panel — optional links to observability UIs (shown on /app/dev for role dev).
# Typical: SSH tunnel → http://127.0.0.1:3333, or public HTTPS if Nginx proxies Grafana (see monitoring/nginx-grafana.example.conf).
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_DEV_GRAFANA_URL=http://127.0.0.1:3333 OR https://grafana.example.com
# NEXT_PUBLIC_DEV_PROMETHEUS_URL=http://127.0.0.1:9090
# NEXT_PUBLIC_DEV_LOKI_URL=http://127.0.0.1:3100
# NEXT_PUBLIC_DEV_CADVISOR_URL=http://127.0.0.1:8088

# -----------------------------------------------------------------------------
# Layout audit (Playwright) – optional; only needed for yarn layout:audit
# -----------------------------------------------------------------------------
# Prefer putting these in frontend/.env.layout-audit (ignored by git).
# LAYOUT_AUDIT_BASE_URL=  # default http://localhost:3002
# LAYOUT_AUDIT_PATHS=     # optional: app,account,stats (multi-page crawl)
# LAYOUT_AUDIT_DECK_ID=   # optional: append /app/decks/{id} (+ study if INCLUDE_STUDY=1)
# LAYOUT_AUDIT_INCLUDE_STUDY=1
# LAYOUT_AUDIT_STUDY_QUERY=atRiskOnly=true
# LAYOUT_AUDIT_SKIP_AUTH=1  # public routes only (no login)
# LAYOUT_AUDIT_MIN_TOUCH_PX=44
# LAYOUT_AUDIT_FAIL_ON_HORIZONTAL_OVERFLOW=1
# LAYOUT_AUDIT_FAIL_ON_MOBILE_OVERFLOW_ONLY=1
# LAYOUT_AUDIT_MAX_SMALL_TAPS=0
# LAYOUT_AUDIT_MAX_OVERLAPS=10
# LAYOUT_AUDIT_KEYBOARD_SMOKE=1
# LAYOUT_AUDIT_EMAIL=     # existing user email for authenticated /app layout capture
# E2E_TEST_PASSWORD=      # password for that user
